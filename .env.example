DATABASE_URL=postgresql:///yuvaraj

# Required for stable, secure sessions. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret

# Dashboard login. Generate the hash with:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
AUTH_USERNAME=admin
AUTH_PASSWORD_HASH=replace-with-generated-password-hash

# Keep false for local http://127.0.0.1 development. Use true when serving over HTTPS.
AUTH_COOKIE_SECURE=false
AUTH_SESSION_HOURS=12
